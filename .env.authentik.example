# Run the wdio E2E suite against a local, hermetic Authentik instance
# instead of Auth0 or the built-in dev-oidc mock. Useful for iterating on
# specs.wdio/helpers/idp/authentik.ts or on the blueprint that provisions it.
#
# 1. Start Authentik (own Postgres + Redis, isolated from the app's DB) -
#    the compose file lives with the CI composite action that also uses it:
#      docker compose -f .github/actions/setup-authentik/docker-compose.yml up -d --wait
#
#    The blueprint at .github/actions/setup-authentik/blueprints/e2e-test-setup.yaml
#    is applied automatically on first boot. If you edit the blueprint while
#    the stack is already running, the file watcher does not reliably pick up
#    changes through a bind mount - re-apply it explicitly:
#      docker compose -f .github/actions/setup-authentik/docker-compose.yml \
#        exec worker ak apply_blueprint custom/e2e-test-setup.yaml
#
# 2. Export these (e.g. `source .env.authentik.example` after copying, or
#    prefix the npm command with them) and run the suite:
#      USE_PGLITE=true npm run wdio:fast -- --suite auth
#    (USE_PGLITE keeps this hermetic - no real app Postgres involved either.)

export TEST_IDP=authentik
export TEST_USERS=alice@example.com,bob@example.com,charlie@example.com,dora@example.com
export TEST_USERS_PWD=test-password-123

export AUTH_ISSUER_BASE_URL=http://localhost:9000/application/o/linkedrecords-e2e/
export AUTH_CLIENT_ID=linkedrecords-e2e
export AUTH_CLIENT_SECRET=e2e-test-client-secret-do-not-use-in-prod
export AUTH_COOKIE_SIGNING_SECRET=somesigningsecret

export QUOTA_COUNT_KV_RECORDS=true
export QUOTA_COUNT_LT_RECORDS=true

# For TEST_AUTH_MODE=public instead of the confidential default: a separate
# public-type client (no secret - the SPA exchanges the code itself via
# PKCE; Authentik's token endpoint requires client auth for confidential
# clients, which a browser-only exchange never sends). The token audience is
# the client_id, since authentik sets aud to it by default. Note the
# different AUTH_ISSUER_BASE_URL too: each Authentik provider defaults to
# issuer_mode=per_provider, so its issuer path is its own application slug
# ("linkedrecords-e2e-public", not "linkedrecords-e2e") - a token issued for
# one is rejected by a server configured with the other's issuer URL.
# export TEST_AUTH_MODE=public
# export AUTH_ISSUER_BASE_URL=http://localhost:9000/application/o/linkedrecords-e2e-public/
# export AUTH_CLIENT_ID=linkedrecords-e2e-public
# export AUTH_TOKEN_AUDIENCE=linkedrecords-e2e-public
# (leave AUTH_CLIENT_SECRET set to whatever - it is ignored in public mode)
