# LinkedRecords local development configuration
# Copy to .env and adjust. Loaded automatically via dotenv.
# Full reference: https://linkedrecords.com/configuration

# --- Database ---------------------------------------------------------------
# Either point to a PostgreSQL server ...
PGHOST=localhost
PGPORT=5432
PGUSER=linkedrecords
PGPASSWORD=linkedrecords
PGDATABASE=linkedrecords
# ... or use the embedded PGlite database instead (comment out PG* above):
# USE_PGLITE=true

# --- URLs -------------------------------------------------------------------
SERVER_BASE_URL=http://localhost:6543
FRONTEND_BASE_URL=http://localhost:6543

# --- Authentication ---------------------------------------------------------
# Built-in mock OIDC provider with one-click test accounts
# (alice@example.com, bob@example.com, charlie@example.com).
# Development only - never enable in production.
AUTH_DEV_MODE=true
AUTH_ISSUER_BASE_URL=http://localhost:6543/dev-oidc
AUTH_CLIENT_ID=linkedrecords-dev
AUTH_TOKEN_AUDIENCE=linkedrecords-dev
ALLOW_HTTP_AUTHENTICATION_HEADER=true

# For a real OIDC provider (Auth0, Keycloak, ...) instead:
# AUTH_DEV_MODE=false
# AUTH_ISSUER_BASE_URL=https://your-tenant.auth0.com/
# AUTH_CLIENT_ID=your-client-id
# AUTH_CLIENT_SECRET=your-client-secret          # confidential client mode
# AUTH_COOKIE_SIGNING_SECRET=a-long-random-secret # confidential client mode

# --- CORS -------------------------------------------------------------------
CORS_ORIGIN=*

# --- Quotas -----------------------------------------------------------------
DEFAULT_STORAGE_SIZE_QUOTA=500
QUOTA_COUNT_KV_RECORDS=true
QUOTA_COUNT_LT_RECORDS=true

# --- Blob storage (optional, S3/MinIO) --------------------------------------
# S3_ENDPOINT=localhost
# S3_PORT=9000
# S3_BUCKET=linkedrecords
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_USE_SSL=false
